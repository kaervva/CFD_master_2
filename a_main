Real,Dimension(0:NI,0:NJ)::T, ResT
Real,Dimension(1:NI-1,1:NJ-1,2)::gradT
Real,Dimension(0:NI,0:NJ,2)::VFlos
integer iNeighCell(4), jNeighCell(4)
real rc(2), rn(2), sf(4,2), rf(4,2), GTE(2), GTF(2), rnc(2), nf(2), Vf(2)

