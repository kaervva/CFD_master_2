  OPEN(IOR,FILE=OutFile)
  write(IOR,*) 'm, time, u_num, u_an, v_num, v_an, w_num, w_an, ', &
               'Fx_num, Fx_an, err_Fx, Fy_num, Fy_an, err_Fy, Mz_num, Mz_an, err_Mz, Re_p, Re_rot'

  do m = 0, Nt
    t = m*dt
    u_an = u0*exp(-kDrag*t)
    v_an = v0*exp(-kDrag*t)
    w_an = w0*exp(-kRot*t)

    Fx_num = -kDrag*u_num
    Fy_num = -kDrag*v_num
    Mz_num = -kRot*w_num
    Fx_an = -kDrag*u_an
    Fy_an = -kDrag*v_an
    Mz_an = -kRot*w_an

    Re_p = dp*ro1*sqrt(u_num**2 + v_num**2)/mu
    Re_rot = dp*ro2*abs(w_num)/mu

    write(IOR,*) m, t, u_num, u_an, v_num, v_an, w_num, w_an, &
                 Fx_num, Fx_an, Fx_num-Fx_an, Fy_num, Fy_an, Fy_num-Fy_an, &
                 Mz_num, Mz_an, Mz_num-Mz_an, Re_p, Re_rot

    rhs_u = Fx_num
    rhs_v = Fy_num
    rhs_w = Mz_num

    if ((Scheme == 2) .and. (m > 0)) then
      u_next = u_num + dt*(1.5*rhs_u - 0.5*rhs_u_old)
      v_next = v_num + dt*(1.5*rhs_v - 0.5*rhs_v_old)
      w_next = w_num + dt*(1.5*rhs_w - 0.5*rhs_w_old)
    else
      u_next = u_num + dt*rhs_u
      v_next = v_num + dt*rhs_v
      w_next = w_num + dt*rhs_w
    endif

    rhs_u_old = rhs_u
    rhs_v_old = rhs_v
    rhs_w_old = rhs_w
    u_num = u_next
    v_num = v_next
    w_num = w_next
  enddo

  CLOSE(IOR)
end

Subroutine C_CompareDampingMoment(ro1, ro2, mu, dp, w0, dt, Nt, Scheme, RunTag)
  integer, parameter :: IODamping = 24, IODampingPlot = 25
  integer :: Nt, Scheme, m
  real :: ro1, ro2, mu, dp, w0, dt
  real :: t, kRot
  real :: w_num, w_next, rhs_w, rhs_w_old
  real :: w_an, Mz_num, Mz_an, Re_rot
  character*(*) RunTag
  character OutFile*160, PlotFile*160

  kRot = 60.0*mu/(dp**2*ro2)
  w_num = w0
  rhs_w_old = -kRot*w_num

  if (len_trim(RunTag) > 0) then
    OutFile = 'analytic_damping_moment_'//trim(RunTag)//'.dat'
    PlotFile = 'analytic_damping_moment_'//trim(RunTag)//'.plt'
  else
    OutFile = 'analytic_damping_moment.dat'
    PlotFile = 'analytic_damping_moment.plt'
  endif

  OPEN(IODamping,FILE=OutFile)
  write(IODamping,*) 'm, time, w_num, w_an, Mz_num, Mz_an, err_Mz, err_w, Re_rot, kRot'

  OPEN(IODampingPlot,FILE=PlotFile)
  write(IODampingPlot,*) 'VARIABLES = "time", "w_num", "w_an", "Mz_num", "Mz_an"'
  write(IODampingPlot,*) 'ZONE I=',Nt+1,', DATAPACKING=POINT'

  do m = 0, Nt
    t = m*dt
    w_an = w0*exp(-kRot*t)
    Mz_num = -kRot*w_num
    Mz_an = -kRot*w_an
    Re_rot = dp*ro2*abs(w_num)/mu

    write(IODamping,*) m, t, w_num, w_an, Mz_num, Mz_an, Mz_num-Mz_an, w_num-w_an, Re_rot, kRot
    write(IODampingPlot,*) t, w_num, w_an, Mz_num, Mz_an

    rhs_w = Mz_num
    if ((Scheme == 2) .and. (m > 0)) then
      w_next = w_num + dt*(1.5*rhs_w - 0.5*rhs_w_old)
    else
      w_next = w_num + dt*rhs_w
    endif

    rhs_w_old = rhs_w
    w_num = w_next
  enddo

  CLOSE(IODamping)
  CLOSE(IODampingPlot)
end

Subroutine C_CompareStokesMagnus(Scheme, RunTag)
  integer, parameter :: IOStokesMagnus = 16
  integer :: Scheme, Nt, m
  real :: ro1, ro2, mu, dp, x0, y0, u0, v0, w0, dt
  real :: t, kDrag, kMag, den, expTerm, cTerm, sTerm
  real :: intCos, intSin
  real :: x_num, y_num, u_num, v_num, x_next, y_next, u_next, v_next
  real :: rhs_u, rhs_v, rhs_x, rhs_y
  real :: rhs_u_old, rhs_v_old, rhs_x_old, rhs_y_old
  real :: x_an, y_an, u_an, v_an, Fx_num, Fy_num, Fx_an, Fy_an
  real :: Re_p, Re_rot
  character*(*) RunTag
  character OutFile*160

  ro1 = 1.0
  ro2 = 2000.0
  mu = 1.82e-5
  dp = 7.0e-4
  x0 = 0.21
  y0 = 0.21
  u0 = 1.0
  v0 = 0.0
  w0 = 3000.0
  dt = 0.005
  Nt = 5000

  kDrag = 18.0*mu/(dp**2*ro2)
  kMag = 0.75*(ro1/ro2)*w0
  den = kDrag**2 + kMag**2

  x_num = x0
  y_num = y0
  u_num = u0
  v_num = v0
  rhs_x_old = u_num
  rhs_y_old = v_num
  rhs_u_old = -kDrag*u_num - kMag*v_num
  rhs_v_old =  kMag*u_num - kDrag*v_num

  if (len_trim(RunTag) > 0) then
    OutFile = 'analytic_stokes_magnus_'//trim(RunTag)//'.dat'
  else
    OutFile = 'analytic_stokes_magnus.dat'
  endif

  OPEN(IOStokesMagnus,FILE=OutFile)
  write(IOStokesMagnus,*) 'm, time, x_num, x_an, y_num, y_an, u_num, u_an, v_num, v_an, ', &
                 'Fx_num, Fx_an, err_Fx, Fy_num, Fy_an, err_Fy, err_x, err_y, err_u, err_v, Re_p, Re_rot'

  do m = 0, Nt
    t = m*dt
    expTerm = exp(-kDrag*t)
    cTerm = cos(kMag*t)
    sTerm = sin(kMag*t)
    u_an = expTerm*(u0*cTerm - v0*sTerm)
    v_an = expTerm*(u0*sTerm + v0*cTerm)
    intCos = (kDrag + expTerm*(-kDrag*cTerm + kMag*sTerm))/den
    intSin = (kMag + expTerm*(-kDrag*sTerm - kMag*cTerm))/den
    x_an = x0 + u0*intCos - v0*intSin
    y_an = y0 + u0*intSin + v0*intCos

    Fx_num = -kDrag*u_num - kMag*v_num
    Fy_num =  kMag*u_num - kDrag*v_num
    Fx_an = -kDrag*u_an - kMag*v_an
    Fy_an =  kMag*u_an - kDrag*v_an
    Re_p = dp*ro1*sqrt(u_num**2 + v_num**2)/mu
    Re_rot = dp*ro2*abs(w0)/mu

    write(IOStokesMagnus,*) m, t, x_num, x_an, y_num, y_an, u_num, u_an, v_num, v_an, &
                   Fx_num, Fx_an, Fx_num-Fx_an, Fy_num, Fy_an, Fy_num-Fy_an, &
                   x_num-x_an, y_num-y_an, u_num-u_an, v_num-v_an, Re_p, Re_rot

    rhs_x = u_num
    rhs_y = v_num
    rhs_u = Fx_num
    rhs_v = Fy_num

    if ((Scheme == 2) .and. (m > 0)) then
      x_next = x_num + dt*(1.5*rhs_x - 0.5*rhs_x_old)
      y_next = y_num + dt*(1.5*rhs_y - 0.5*rhs_y_old)
      u_next = u_num + dt*(1.5*rhs_u - 0.5*rhs_u_old)
      v_next = v_num + dt*(1.5*rhs_v - 0.5*rhs_v_old)
    else
      x_next = x_num + dt*rhs_x
      y_next = y_num + dt*rhs_y
      u_next = u_num + dt*rhs_u
      v_next = v_num + dt*rhs_v
    endif

    rhs_x_old = rhs_x
    rhs_y_old = rhs_y
    rhs_u_old = rhs_u
    rhs_v_old = rhs_v
    x_num = x_next
    y_num = y_next
    u_num = u_next
    v_num = v_next
  enddo

  CLOSE(IOStokesMagnus)
end

