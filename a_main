Program Main
  character(*), parameter:: InputFile='input.txt' ! name of input file
  character MeshFile*30        ! name of file with computational mesh
  character OutputFile*30      ! name of output file
  character ParticleOutputFile*160
  character InterpCompareFile*160
  character SchemeName*20
  character ParamSchemeName*20
  character BCName*20
  character RunTag*80
  character OutputSuffix*120
  integer, parameter:: IO = 12 ! input-output unit
  integer, parameter:: IOI = 14 ! interpolation comparison output unit

  !Mesh-arrays
  real,allocatable,dimension(:,:):: X,Y,CellVolume ! scalar arrays
  real,allocatable,dimension(:,:,:):: CellCenter,IFaceCenter,IFaceVector,JFaceCenter,JFaceVector ! vector arrays
  
  !Fields-arrays 
  real,allocatable,dimension(:,:):: T, TFlos, T_Err, P, divVT, divVT_Exact, divVT_error, LapT, LapT_error, LapT_Exact ! scalar arrays
  real,allocatable,dimension(:,:):: rotV, rotV_Exact, rotV_error, ResT, ResC, ResMx, ResMy
  real,allocatable,dimension(:,:,:):: V, GradT, gradT_Exact, gradT_error, GradP ! vector arrays
  real,allocatable,dimension(:,:,:):: VFlos
  real :: Re, Pr, mu, Mz
  logical :: HasFlosT, HasFlosV
  integer :: IP, JP, IP1, JP1
  integer :: Scheme, ParamScheme, BCMode
  integer :: RestTest, RestNt, ios
  real :: gx, gy
  real :: RestDt, RestU0, RestV0, RestW0
  real :: PressureScale
  real :: rhs_x, rhs_y, rhs_u, rhs_v, rhs_w
  real :: rhs_x_old, rhs_y_old, rhs_u_old, rhs_v_old, rhs_w_old
  real :: u_m_prev, v_m_prev
  real :: gradPx_p, gradPy_p
  real :: Vx_center, Vy_center, rotV_center, gradPx_center, gradPy_center
  real :: Vx_idw, Vy_idw, rotV_idw, gradPx_idw, gradPy_idw
  real :: FDragX, FDragY, FMagX, FMagY, FAddX, FAddY, FGravX, FGravY, FPressX, FPressY
  real :: FxAnalytic, FyAnalytic, MzAnalytic, RePart, ReRot, MassCorr
  real :: Xcros, Ycros, St
  
!===  READ INPUT FILE ===
  WRITE(*,*) 'Read input file: ', InputFile
  OPEN(IO,FILE=InputFile)
  READ(IO,*) MeshFile  ! read name of file with computational mesh
  READ(IO,*) power     !power of polynom
  READ(IO,*) par       !parameter in polynom
  read(IO,*) niterg      !GradT
  read(IO,*) mode       !div
  CLOSE(IO)
  
  OutputFile=MeshFile(1:len(trim(MeshFile))-3)//"plt" ! if mesh=base.msh then output=base.plt

  write(*,*) "MeshFile,OutputFile,power,par, niterg, mode"
  write(*,*) MeshFile,OutputFile,power,par,niterg,mode
  
!=== READ NODES NUMBER (NI,NJ) FROM FILE WITH MESH ===
  WRITE(*,*) 'Read nodes number from file: ', MeshFile
  OPEN(IO,FILE = MeshFile)
  READ(IO,*) NI,NJ
  WRITE(*,*) 'NI, NJ = ',NI,NJ

!=== ALLOCATE ALL ARRAYS ACCORDING TO MESH SIZE ===
  WRITE(*,*) 'Allocate arrays'       
  allocate(X(NI,NJ)) ! mesh nodes X-coordinates
  allocate(Y(NI,NJ)) ! mesh nodes Y-coordinates
  allocate(CellVolume(NI-1,NJ-1))   ! Cell Volumes    
  allocate(CellCenter(0:NI,0:NJ,2)) ! Cell Centers
  allocate(IFaceCenter(NI,NJ-1,2)) ! Face Centers for I-faces
  allocate(IFaceVector(NI,NJ-1,2)) ! Face Vectors for I-faces
  allocate(JFaceCenter(NI-1,NJ,2)) ! Face Centers for J-faces
  allocate(JFaceVector(NI-1,NJ,2)) ! Face Vectors for J-faces
  
  allocate(T(0:NI,0:NJ), ResT(0:NI,0:NJ), TFlos(0:NI,0:NJ), T_Err(0:NI,0:NJ))            ! Temperature
  allocate(gradT(1:NI-1,1:NJ-1,2))    ! Gradient of Temperature
  allocate(gradT_Exact, gradT_error, mold = gradT) !Allocate VECTOR arrays for inner cells

  allocate(V(0:NI,0:NJ,2), VFlos(0:NI,0:NJ,2))          ! Velocity
  allocate(divVT(1:NI-1,1:NJ-1))    ! Divergence of Temperature and Velocity
  allocate(divVT_Exact, divVT_error, mold = divVT) !Allocate VECTOR arrays for inner cells

  allocate(LapT, LapT_Exact, LapT_error, mold = divVT)
  allocate(rotV, rotV_Exact, rotV_error, mold = divVT)
  allocate(ResC, ResMx, ResMy, P, mold = T)
  allocate(gradP(1:NI-1,1:NJ-1,2))
  
!=== READ GRID ===
  WRITE(*,*) 'Read mesh from file: ', MeshFile
  Call B_ReadMesh(IO,NI,NJ,X,Y)
  CLOSE(IO)

!=== READ T FLOS ===
  TFlos = 1.
  inquire(FILE = "T_Flos.txt", EXIST = HasFlosT)
  if (HasFlosT) then
    OPEN(IO,FILE = "T_Flos.txt")
    WRITE(*,*) 'Read field from file: T_Flos.txt'
    read(IO,*)  NIV, NJV
    READ(IO,*) ((TFlos(I,J), I=0,NIV-1),J=0,NJV-1)
    CLOSE(IO)
  endif

!=== READ V FLOS ===
  VFlos = 1.
  inquire(FILE = "VelocityField.txt", EXIST = HasFlosV)
  if (HasFlosV) then
    OPEN(IO,FILE = "VelocityField.txt")
    WRITE(*,*) 'Read field from file: VelocityField.txt'
    read(IO,*)  NIV, NJV
    READ(IO,*) ((VFlos(I,J,1), VFlos(I,J,2), I=0,NIV-1),J=0,NJV-1)
    CLOSE(IO)
  endif
!=== CALCULATE METRIC ===
  WRITE(*,*) 'Calculate metric'   
  CellCenter = 0.    
  Call B_CalcMetric(NI,NJ,X,Y,CellCenter,CellVolume,IFaceCenter,IFaceVector,JFaceCenter,JFaceVector) 
  
!=== INITIATE FIELDS ===
  WRITE(*,*) 'Initiate fields'       
  DO  J = 0,NJ
    DO  I = 0,NI
      cX = CellCenter(i,j,1)
      cY = CellCenter(i,j,2)
      T(I,J) = Polynom(cX, cY, power, par)
      V(i,j,1) = VelocityX(cX, cY)
      V(i,j,2) = VelocityY(cX, cY)
    ENDDO
  ENDDO
  write(*,*) "Temperature: Min, Max", minval(T),maxval(T)
  write(*,*) "Velocity: Min, Max", minval(V),maxval(V)

!=== INITIATE EXACT SOLUTIONS ===
  DO  J = 1,NJ-1
    DO  I = 1,NI-1
      cX = CellCenter(i,j,1)
      cY = CellCenter(i,j,2)
      gradT_Exact(i,j,1) = PolynomGX(cX, cY, power, par)
      gradT_Exact(i,j,2) = PolynomGY(cX, cY, power, par)
      divVT_Exact(i,j) = PolynomVelocityDIV(cX, cY, power, par)
      LapT_Exact(i,j) = PolynomLP(cX, cY, power, par)
      rotV_Exact(i,j) = PolynomRotor(cX, cY, power, par)
    ENDDO
  ENDDO
  
!=== CALCULATE GRADIENT ===
  WRITE(*,*) 'Calculate derivatives'  

  write(*,*) 'Gradient Error: MAX, BOUNDARY_X, BOUNDARY_Y, CENTER_X, CENTER_Y'
  do iter = 1, niterg
    Call B_CalcGradient(ni,nj,CellCenter,CellVolume,IFaceCenter,IFaceVector,JFaceCenter,JFaceVector,T,gradT)
    ! gradT_error = abs(gradT_Exact-gradT)/gradT_Exact 
    ! write(*,*) maxval(gradT_error), gradT_error(1,1,:), gradT_error(NI/2,NJ/2,:) 
  end do

  !=== CALCULATE DIVERGENCE ===
  WRITE(*,*) 'Calculate derivatives'  
  Call B_CalcDivergence(ni,nj,CellCenter,CellVolume,IFaceCenter,IFaceVector,JFaceCenter,JFaceVector,&
                        T,V, divVT, gradT,P, gradP,dt,mode, 0, 0)
  ! divVT_error = abs(divVT_Exact-divVT)/divVT_Exact 
  ! write(*,*) 'Divergence Error: MAX, BOUNDARY, CENTER'
  ! write(*,*) maxval(divVT_error), divVT_error(1,1), divVT_error(NI/2,NJ/2) 
  
  !=== CALCULATE Laplacian ===
  WRITE(*,*) 'Calculate derivatives'  
  Call B_CalcLaplacian(ni,nj,CellCenter,CellVolume,IFaceCenter,IFaceVector,JFaceCenter,JFaceVector, &
                        T, gradT,LapT, 0)
  ! LapT_error = abs(LapT_Exact-LapT)/LapT_Exact 
  ! write(*,*) 'Laplacian Error: MAX, BOUNDARY, CENTER'
  ! write(*,*) maxval(LapT_error), LapT_error(1,1), LapT_error(NI/2,NJ/2) 

  !=== CALCULATE Laplacian ===
  WRITE(*,*) 'Calculate derivatives'  
  Call B_CalcRotor(ni,nj,CellCenter,CellVolume,IFaceCenter,IFaceVector,JFaceCenter,JFaceVector, V, rotV)
  ! rotV_error = abs(rotV_Exact-rotV)!/rotV_Exact 
  ! write(*,*) 'Rotor Error: MAX, BOUNDARY, CENTER'
  ! write(*,*) maxval(rotV_error), rotV_error(1,1), rotV_error(NI/2,NJ/2) 

  !=== CALCULATE RESIDUAL TEMPERATURE ===
  OPEN(IO,FILE = MeshFile)
  READ(IO,*) NI,NJ
  WRITE(*,*) 'NI, NJ = ',NI,NJ
  Call B_ReadMesh(IO,NI,NJ,X,Y)
  CLOSE(IO)

  !=== INITIATE FIELDS ===
  WRITE(*,*) 'Initiate fields'       
  DO  J = 0,NJ
    DO  I = 0,NI
      cX = CellCenter(i,j,1)
      cY = CellCenter(i,j,2)
    ENDDO
  ENDDO

  !=== CALCULATE METRIC ===
  WRITE(*,*) 'Calculate metric'   
  CellCenter = 0.    
  Call B_CalcMetric(NI,NJ,X,Y,CellCenter,CellVolume,IFaceCenter,IFaceVector,JFaceCenter,JFaceVector) 

!=== INITIATE EXACT SOLUTIONS ===
  DO  J = 1,NJ-1
    DO  I = 1,NI-1
      cX = CellCenter(i,j,1)
      cY = CellCenter(i,j,2)
    ENDDO
  ENDDO

  OPEN(IO,FILE='input_2.txt')
  READ(IO,*) nit     !iter
  read(IO,*) mode       !div
  read(IO,*) Re      
  read(IO,*) Pr      
  read(IO,*) dt
  CLOSE(IO)

  !Initial guess
  V = 0.
  T = 1.
  P = 0.

  !Boundary Conditions: lid-driven cavity, left/right isothermal,
  !top/bottom adiabatic and no-penetration/no-slip walls.
  Call B_ApplyFlowBC(NI,NJ,T,V,P)

  !Iterations
  OPEN(IO,FILE="his.txt")
  write(*,*) "Iteration procces, iter=", nit

  do it = 0, nit

    !Residual for Energy equation
    gradT = 0.

    Call B_CalcGradient(ni,nj,CellCenter,CellVolume,IFaceCenter,IFaceVector,JFaceCenter,JFaceVector, T, gradT)
    !Call B_CalcResT(NI,NJ,CellCenter,CellVolume,IFaceCenter,IFaceVector,JFaceCenter,JFaceVector, Re, Pr, VFlos, T, GradT, ResT)
    Call B_CalcDivergence(ni,nj,CellCenter,CellVolume,IFaceCenter,IFaceVector,JFaceCenter,JFaceVector,&
                        T,V, divVT,gradT, P,gradP,dt, mode, 1, 0)
    Call B_CalcLaplacian(ni,nj,CellCenter,CellVolume,IFaceCenter,IFaceVector,JFaceCenter,JFaceVector, &
                        T, gradT,LapT, 1)

    ResT(1:NI-1, 1:NJ-1) = divVT - LapT/(Re*Pr)

    !Pressure Gradient
    GradP = 0.
    Call B_CalcGradient(ni,nj,CellCenter,CellVolume,IFaceCenter,IFaceVector,JFaceCenter,JFaceVector, P, gradP)

    !Residual for X-Momentum
    gradT = 0.

    Call B_CalcGradient(ni,nj,CellCenter,CellVolume,IFaceCenter,IFaceVector,JFaceCenter,JFaceVector, V(:,:,1), gradT)
    Call B_CalcDivergence(ni,nj,CellCenter,CellVolume,IFaceCenter,IFaceVector,JFaceCenter,JFaceVector,&
                        V(:,:,1), V, divVT,gradT, P,gradP, dt, mode, 1, 1)
    Call B_CalcLaplacian(ni,nj,CellCenter,CellVolume,IFaceCenter,IFaceVector,JFaceCenter,JFaceVector, &
                        V(:,:,1), gradT, LapT, 0)
                        

    ResMx(1:NI-1, 1:NJ-1) = divVT - LapT/Re + GradP(:,:,1)


    !Residual for Y-Momentum
    gradT = 0.

    Call B_CalcGradient(ni,nj,CellCenter,CellVolume,IFaceCenter,IFaceVector,JFaceCenter,JFaceVector, V(:,:,2),gradT)
    Call B_CalcDivergence(ni,nj,CellCenter,CellVolume,IFaceCenter,IFaceVector,JFaceCenter,JFaceVector,&
                        V(:,:,2),V, divVT,gradT, P,gradP, dt,mode, 1, 1)
    Call B_CalcLaplacian(ni,nj,CellCenter,CellVolume,IFaceCenter,IFaceVector,JFaceCenter,JFaceVector, &
                        V(:,:,2), gradT, LapT, 0)

    ResMy(1:NI-1, 1:NJ-1) = divVT - LapT/Re + GradP(:,:,2)

    !Residuals for Continuity 
    Call B_CalcDivergence(ni,nj,CellCenter,CellVolume,IFaceCenter,IFaceVector,JFaceCenter,JFaceVector,&
                        T, V, divVT, gradT, P, gradP, dt,0, 1, 1)
    ResC(1:NI-1, 1:NJ-1) = DivVT


    ResTm = maxval(abs(ResT(1:NI-1, 1:NJ-1)))
    ResMxm = maxval(abs(ResMx(1:NI-1, 1:NJ-1)))
    ResMym = maxval(abs(ResMy(1:NI-1, 1:NJ-1)))
    ResCm = maxval(abs(ResC(1:NI-1, 1:NJ-1)))

    write(IO,*) it, ResTm, ResMxm, ResMym, ResCm

    if (mod(it,100) == 0) then 
      write(*,*) it, ResTm, ResMxm, ResMym, ResCm
    end if

    T(1:NI-1,1:NJ-1) = T(1:NI-1,1:NJ-1) - ResT(1:NI-1,1:NJ-1)*dt
    V(1:NI-1,1:NJ-1,1) = V(1:NI-1,1:NJ-1,1) - ResMx(1:NI-1,1:NJ-1)*dt
    V(1:NI-1,1:NJ-1,2) = V(1:NI-1,1:NJ-1,2) - ResMy(1:NI-1,1:NJ-1)*dt
    P(1:NI-1,1:NJ-1) = P(1:NI-1,1:NJ-1) - ResC(1:NI-1,1:NJ-1)*dt

    Call B_ApplyFlowBC(NI,NJ,T,V,P)
  end do

  close(IO)

  gradP = 0.
  Call B_CalcGradient(ni,nj,CellCenter,CellVolume,IFaceCenter,IFaceVector,JFaceCenter,JFaceVector, P, gradP)
  Call B_CalcRotor(ni,nj,CellCenter,CellVolume,IFaceCenter,IFaceVector,JFaceCenter,JFaceVector, V, rotV)

  OPEN(IO,FILE='input_particle.txt')
  READ(IO,*) ro1, ro2     
  read(IO,*) mu       
  read(IO,*) dp      
  read(IO,*) x0,y0      
  read(IO,*) u0,v0
  read(IO,*) w0     
  read(IO,*) dt     
  read(IO,*) Nt
  read(IO,*) Scheme
  read(IO,*) ParamScheme
  read(IO,*) BCMode
  read(IO,*) gx, gy
  RestTest = 1
  RestU0 = 0.01
  RestV0 = 0.005
  RestW0 = 5.0e-4
  RestDt = 0.01
  RestNt = 5000
  PressureScale = 0.0
  RunTag = ''
  read(IO,*,IOSTAT=ios) RestTest
  if (ios == 0) read(IO,*,IOSTAT=ios) RestU0, RestV0, RestW0
  if (ios == 0) read(IO,*,IOSTAT=ios) RestDt
  if (ios == 0) read(IO,*,IOSTAT=ios) RestNt
  if (ios == 0) read(IO,*,IOSTAT=ios) RunTag
  if (ios == 0) read(IO,*,IOSTAT=ios) PressureScale
  CLOSE(IO)

  select case(Scheme)
  case(2)
    SchemeName = 'adams_bashforth'
  case default
    SchemeName = 'euler'
  end select

  select case(ParamScheme)
  case(2)
    ParamSchemeName = 'idw'
  case default
    ParamSchemeName = 'cell_center'
  end select

  select case(BCMode)
  case(1)
    BCName = 'bc_angle'
  case default
    BCName = 'bc_constant'
  end select

  OutputSuffix = ''
  if (len_trim(RunTag) > 0) OutputSuffix = '_'//trim(RunTag)

  ParticleOutputFile = 'output_particle_'//trim(SchemeName)//'_'//trim(ParamSchemeName)//'_'// &
                       trim(BCName)//trim(OutputSuffix)//'.dat'
  InterpCompareFile = 'interp_compare_'//trim(SchemeName)//'_'//trim(ParamSchemeName)//'_'// &
                      trim(BCName)//trim(OutputSuffix)//'.dat'

  Vref = 1.0
  Lref = 1.0

  Sk = ro2*dp**2*Vref/(18*mu*Lref)

  WRITE(*,*) 'Particle: ', 'd= ', dp, 'ro =', ro2
  WRITE(*,*) 'Sk = ', Sk
  WRITE(*,*) 'Iterate process: ', 'NT= ', NT, 'dt =', dt

  if (RestTest == 1) then
    call C_OutputModelFields(NI, NJ, X, Y, V, rotV, gradP, RunTag)
    call C_RestingLiquidForceMomentCompare(ro1, ro2, mu, dp, RestU0, RestV0, RestW0, RestDt, RestNt, Scheme, RunTag)
    call C_CompareStokesMagnus(Scheme, RunTag)
    call C_CompareGravity(Scheme, RunTag)
    call C_CompareDampingMoment(ro1, ro2, mu, dp, RestW0, RestDt, RestNt, Scheme, RunTag)
    call C_ParametricRuns(NI, NJ, X, Y, CellCenter, CellVolume, IFaceVector, JFaceVector, V, gradP, rotV, &
                            ro1, ro2, mu, dp, x0, y0, u0, v0, w0, dt, Nt, Scheme, ParamScheme, BCMode, gx, gy, RunTag)
  endif

  x_m = x0
  y_m = y0 
  u_m = u0
  v_m = v0 
  w_m = w0 
  u_m_prev = u_m
  v_m_prev = v_m
  rhs_x_old = u_m
  rhs_y_old = v_m
  rhs_u_old = 0.
  rhs_v_old = 0.
  rhs_w_old = 0.

  OPEN(IO,FILE="stokes_number.dat")
  write(IO,*) 'Stokes_number = ', Sk
  write(IO,*) 'rho_gas, rho_particle, mu, dp = ', ro1, ro2, mu, dp
  CLOSE(IO)

  OPEN(IO,FILE=ParticleOutputFile)
  write(IO,*) 'm, time, x_m, y_m, u_m, v_m, w_m, Fx, Fy, Mz'

  OPEN(IOI,FILE=InterpCompareFile)
  write(IOI,*) 'm, time, x_m, y_m, IP, JP, ', &
               'Vx_center, Vy_center, rotV_center, gradPx_center, gradPy_center, ', &
               'Vx_idw, Vy_idw, rotV_idw, gradPx_idw, gradPy_idw, ', &
               'dVx, dVy, dRotV, dGradPx, dGradPy'
  !V = 0.

  do m = 1, NT 
    IP = -1
    JP = -1

    call Search_p(x_m, y_m, NI, NJ, X, Y, CellVolume, IP, JP)

    if ((IP < 1) .or. (JP < 1)) then
      write(*,*) 'Particle is outside the domain before force calculation'
      exit
    endif

    call C_InterpolateGas(x_m, y_m, NI, NJ, CellCenter, V, gradP, rotV, IP, JP, 1, &
                          Vx_center, Vy_center, rotV_center, gradPx_center, gradPy_center)
    call C_InterpolateGas(x_m, y_m, NI, NJ, CellCenter, V, gradP, rotV, IP, JP, 2, &
                          Vx_idw, Vy_idw, rotV_idw, gradPx_idw, gradPy_idw)

    write(IOI,*) m, m*dt, x_m, y_m, IP, JP, &
                 Vx_center, Vy_center, rotV_center, gradPx_center, gradPy_center, &
                 Vx_idw, Vy_idw, rotV_idw, gradPx_idw, gradPy_idw, &
                 Vx_idw-Vx_center, Vy_idw-Vy_center, rotV_idw-rotV_center, &
                 gradPx_idw-gradPx_center, gradPy_idw-gradPy_center

    if (ParamScheme == 2) then
      Vx_p = Vx_idw
      Vy_p = Vy_idw
      rotV_p = rotV_idw
      gradPx_p = gradPx_idw
      gradPy_p = gradPy_idw
    else
      Vx_p = Vx_center
      Vy_p = Vy_center
      rotV_p = rotV_center
      gradPx_p = gradPx_center
      gradPy_p = gradPy_center
    endif

    Fx = 0.0
    Fy = 0.0
    Mz = 0.0

    call c_ForceDetailed(ro1, ro2, mu, dp, u_m, v_m, w_m, Vx_p, Vy_p, Fx, Fy, Mz, rotV_p, &
                         dt, u_m_prev, v_m_prev, gradPx_p, gradPy_p, gx, gy, PressureScale, &
                         FDragX, FDragY, FMagX, FMagY, FAddX, FAddY, FGravX, FGravY, &
                         FPressX, FPressY, FxAnalytic, FyAnalytic, MzAnalytic, RePart, ReRot, MassCorr)

    write(IO,*) m, m*dt, x_m, y_m, u_m, v_m, w_m, Fx, Fy, Mz
    if ((m <= 20) .or. (mod(m,100) == 0)) then
      write(*,*) 'it =', m, 'x=', x_m, 'y=', y_m, 'u=', u_m, 'v=', v_m, 'w=', w_m, 'Fx=', Fx, 'Fy=', Fy, 'Mz=', Mz,&
                'IP=', IP, 'JP=', JP
    endif

    rhs_x = u_m
    rhs_y = v_m
    rhs_u = Fx
    rhs_v = Fy
    rhs_w = Mz

    if ((Scheme == 2) .and. (m > 1)) then
      x_m1 = x_m + dt*(1.5*rhs_x - 0.5*rhs_x_old)
      y_m1 = y_m + dt*(1.5*rhs_y - 0.5*rhs_y_old)
      u_m1 = u_m + dt*(1.5*rhs_u - 0.5*rhs_u_old)
      v_m1 = v_m + dt*(1.5*rhs_v - 0.5*rhs_v_old)
      w_m1 = w_m + dt*(1.5*rhs_w - 0.5*rhs_w_old)
    else
      x_m1 = x_m + dt*rhs_x
      y_m1 = y_m + dt*rhs_y
      u_m1 = u_m + dt*rhs_u
      v_m1 = v_m + dt*rhs_v
      w_m1 = w_m + dt*rhs_w
    endif
    !v_an = sqrt(u0**2)*exp(-Fx*dt*m/u_m)
    !v_r = sqrt(u_m**2)
    !print*, 'v_an = ', v_an, 'v = ', v_r, exp(-Fx*dt*m), Fx, dt

    !CHECK BOUNDARY

    call Search_p(x_m1, y_m1, NI, NJ, X, Y, CellVolume, IP1, JP1)
    IP = IP1
    JP = JP1
    if ((x_m1 < minval(X)) .or. (x_m1 > maxval(X)) .or. &
        (y_m1 < minval(Y)) .or. (y_m1 > maxval(Y))) then
      IP = -1
      JP = -1
    endif
    if ((m <= 20) .or. (mod(m,100) == 0)) print*, ip, jp, IP .eq. -1
    if ((IP < 0) .and. (JP < 0)) then 
      Xcros = 0.0
      Ycros = 0.0
      St = 0.0
      call C_Boundary(X,Y,IFaceVector, JFaceVector, NI, NJ, x_m, y_m, u_m, v_m, w_m, x_m1, &
                      y_m1, u_m1, v_m1, w_m1, Xcros, Ycros, St, dp, BCMode)
      if (St < 0.5) then
        call C_BoundaryFallbackBox(X,Y,NI,NJ, x_m, y_m, u_m, v_m, w_m, x_m1, &
                                  y_m1, u_m1, v_m1, w_m1, Xcros, Ycros, St, dp, BCMode)
      endif
      if (St < 0.5) then
        write(*,*) 'WARNING: boundary crossing was not found at step ', m
        write(*,*) 'old point = ', x_m, y_m, 'new point = ', x_m1, y_m1
        exit
      endif
      call C_ClampPointToBox(X,Y,NI,NJ, Xcros, Ycros, 0.0)
      call C_ClampPointToBox(X,Y,NI,NJ, x_m1, y_m1, 1.0e-6)
      if ((m <= 20) .or. (mod(m,100) == 0)) then
        write(*,*) 'It = ', m, 'x = ', Xcros, 'y = ', Ycros, 'IP = ', IP, 'JP = ', JP
        write(*,*) 'u_m = ', u_m, 'v_m = ', v_m, 'w_m = ', w_m, 'Fx = ', Fx, 'Fy = ', Fy
      endif
      write(IO,*)  m, m*dt, Xcros, Ycros, u_m, v_m, w_m, Fx, Fy, Mz
    endif

    u_m_prev = u_m
    v_m_prev = v_m
    rhs_x_old = rhs_x
    rhs_y_old = rhs_y
    rhs_u_old = rhs_u
    rhs_v_old = rhs_v
    rhs_w_old = rhs_w

    x_m = x_m1 
    y_m = y_m1 
    u_m = u_m1 
    v_m = v_m1 
    w_m = w_m1 
  end do 

  CLOSE(IOI)


  T_Err = (T-TFlos)/TFlos
  VFlos = (V-VFlos)/VFlos

!=== OUTPUT FIELDS ===
  WRITE(*,*) 'Output fields to file: ', OutputFile       
  Open(IO,FILE=OutputFile)
  Call B_OutputFields(IO,NI,NJ,X,Y,T,V,gradT,gradT_Exact, gradT_error, divVT, divVT_Exact, divVT_error,&
                      LapT, LapT_Exact, LapT_error, rotV, rotV_Exact, rotV_error, ResT, P, T_Err, VFlos)
  Close(IO)

END PROGRAM Main  

Subroutine C_InterpolateGas(x_m, y_m, NI, NJ, CellCenter, V, gradP, rotV, IP, JP, ParamScheme, &
                            Vx_p, Vy_p, rotV_p, gradPx_p, gradPy_p)
  REAL CellCenter(0:NI,0:NJ,2)
  REAL V(0:NI,0:NJ,2), gradP(1:NI-1,1:NJ-1,2), rotV(1:NI-1,1:NJ-1)
  integer :: IP, JP, ParamScheme
  integer :: ii(5), jj(5)
  real :: x_m, y_m, Vx_p, Vy_p, rotV_p, gradPx_p, gradPy_p
  real :: d(5), w(5), Rmax, wsum, eps

  if (ParamScheme /= 2) then
    Vx_p = V(IP,JP,1)
    Vy_p = V(IP,JP,2)
    rotV_p = rotV(IP,JP)
    gradPx_p = gradP(IP,JP,1)
    gradPy_p = gradP(IP,JP,2)
    return
  endif

  ii = (/ IP, max(1,IP-1), min(NI-1,IP+1), IP, IP /)
  jj = (/ JP, JP, JP, max(1,JP-1), min(NJ-1,JP+1) /)
  eps = 1.0e-12

  do k = 1, 5
    d(k) = sqrt((x_m-CellCenter(ii(k),jj(k),1))**2 + (y_m-CellCenter(ii(k),jj(k),2))**2)
    if (d(k) < eps) then
      Vx_p = V(ii(k),jj(k),1)
      Vy_p = V(ii(k),jj(k),2)
      rotV_p = rotV(ii(k),jj(k))
      gradPx_p = gradP(ii(k),jj(k),1)
      gradPy_p = gradP(ii(k),jj(k),2)
      return
    endif
  enddo

  Rmax = maxval(d)
  wsum = 0.
  Vx_p = 0.
  Vy_p = 0.
  rotV_p = 0.
  gradPx_p = 0.
  gradPy_p = 0.

  do k = 1, 5
    w(k) = (Rmax/d(k) - 1.0)**2
    wsum = wsum + w(k)
    Vx_p = Vx_p + w(k)*V(ii(k),jj(k),1)
    Vy_p = Vy_p + w(k)*V(ii(k),jj(k),2)
    rotV_p = rotV_p + w(k)*rotV(ii(k),jj(k))
    gradPx_p = gradPx_p + w(k)*gradP(ii(k),jj(k),1)
    gradPy_p = gradPy_p + w(k)*gradP(ii(k),jj(k),2)
  enddo

  Vx_p = Vx_p/wsum
  Vy_p = Vy_p/wsum
  rotV_p = rotV_p/wsum
  gradPx_p = gradPx_p/wsum
  gradPy_p = gradPy_p/wsum
End Subroutine

Subroutine C_Boundary(X,Y,IFaceVector, JFaceVector, NI, NJ, x_m, y_m, u_m, v_m, w_m, x_m1, &
                      y_m1, u_m1, v_m1, w_m1, Xcros, Ycros, St, dp, BCMode)
  REAL  JFaceVector( NI-1,NJ,2)  ,IFaceVector( NI,NJ-1,2)
  Real,Dimension(NI,NJ):: X,Y
  real :: Xcros, Ycros
  real :: Icr
  real :: n(2), len_n, dp
  integer :: BCMode

  St = 0
  !J = 1 - wall St = 1
  !J = NJ - wall St = 2
  !I = 1 - wall St = 3
  !I = NI - wall St = 4

  do i = 1, NI-1
    call cross_edges(x_m, y_m, x_m1, y_m1, X(I,1), Y(I,1), X(I+1,1), Y(I+1,1), Xcros, Ycros,Icr)
    if (Icr == 1) then 
      St = 1
      ! Boundary events are written to the particle output file in the main loop.
      n(1) = 0.0
      n(2) = -1.0
      call Apply_Boundary(Xcros, Ycros, n, u_m, v_m, u_m1, v_m1, w_m1, x_m1, y_m1, dp, BCMode)
      return 
    end if 
    call cross_edges(x_m, y_m, x_m1, y_m1, X(I,NJ), Y(I,NJ), X(I+1,NJ), Y(I+1,NJ), Xcros, Ycros,Icr)
    if (Icr == 1) then 
      St = 2
      ! Boundary events are written to the particle output file in the main loop.
      n(1) = 0.0
      n(2) = 1.0
      call Apply_Boundary(Xcros, Ycros, n, u_m, v_m, u_m1, v_m1, w_m1, x_m1, y_m1, dp, BCMode)
      return 
    end if 
  end do

  do j = 1, NJ-1
    call cross_edges(x_m, y_m, x_m1, y_m1, X(1,J), Y(1,J), X(1,J+1), Y(1,J+1), Xcros, Ycros,Icr)
    if (Icr == 1) then 
      St = 3
      ! Boundary events are written to the particle output file in the main loop.
      n(1) = -1.0
      n(2) = 0.0
      call Apply_Boundary(Xcros, Ycros, n, u_m, v_m, u_m1, v_m1, w_m1, x_m1, y_m1, dp, BCMode)
      return 
    end if 
    call cross_edges(x_m, y_m, x_m1, y_m1, X(NI,J), Y(NI,J), X(NI,J+1), Y(NI,J+1), Xcros, Ycros,Icr)
    if (Icr == 1) then 
      St = 4
      ! Boundary events are written to the particle output file in the main loop.
      n(1) = 1.0
      n(2) = 0.0
      call Apply_Boundary(Xcros, Ycros, n, u_m, v_m, u_m1, v_m1, w_m1, x_m1, y_m1, dp, BCMode)
      return 
    end if 
  end do

end

