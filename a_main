Subroutine C_GravityExactStep(x, y, u, v, gx, gy, dt, kn, x_next, y_next, u_next, v_next)
  real :: x, y, u, v, gx, gy, dt, kn
  real :: x_next, y_next, u_next, v_next
  real :: x_cur, y_cur, u_cur, v_cur, rem, eps, disc, r1, r2, tau, root
  integer :: hit_count

  x_cur = x
  y_cur = y
  u_cur = u
  v_cur = v
  rem = dt
  eps = 1.0e-8
  hit_count = 0

  do while (rem > eps)
    x_next = x_cur + u_cur*rem + 0.5*gx*rem**2
    y_next = y_cur + v_cur*rem + 0.5*gy*rem**2
    u_next = u_cur + gx*rem
    v_next = v_cur + gy*rem

    if (y_next >= 0.0) exit

    tau = rem
    if (abs(gy) > eps) then
      disc = v_cur**2 - 2.0*gy*y_cur
      if (disc >= 0.0) then
        root = sqrt(disc)
        r1 = (-v_cur + root)/gy
        r2 = (-v_cur - root)/gy
        if ((r1 >= -eps) .and. (r1 <= rem + eps)) tau = max(0.0, r1)
        if ((r2 >= -eps) .and. (r2 <= rem + eps)) tau = min(tau, max(0.0, r2))
      endif
    else if (abs(v_cur) > eps) then
      tau = -y_cur/v_cur
      tau = min(max(tau, 0.0), rem)
    endif

    x_cur = x_cur + u_cur*tau + 0.5*gx*tau**2
    u_cur = u_cur + gx*tau
    v_cur = v_cur + gy*tau
    y_cur = 0.0
    v_cur = -kn*v_cur
    rem = rem - tau
    hit_count = hit_count + 1
    if (hit_count > 10) exit
  enddo

  if (y_next < 0.0) y_next = 0.0
end

Subroutine C_BoundaryFallbackBox(X,Y,NI,NJ, x_m, y_m, u_m, v_m, w_m, x_m1, &
                                 y_m1, u_m1, v_m1, w_m1, Xcros, Ycros, St, dp, BCMode)
  Real,Dimension(NI,NJ):: X,Y
  real :: x_m, y_m, u_m, v_m, w_m, x_m1, y_m1, u_m1, v_m1, w_m1
  real :: Xcros, Ycros, St, dp
  real :: xmin, xmax, ymin, ymax, dx, dy, tau, tau_best, eps
  real :: n(2)
  integer :: BCMode

  xmin = minval(X)
  xmax = maxval(X)
  ymin = minval(Y)
  ymax = maxval(Y)
  dx = x_m1 - x_m
  dy = y_m1 - y_m
  tau_best = 2.0
  eps = 1.0e-10
  St = 0.0
  n = 0.0

  if (abs(dy) > eps) then
    if (y_m1 < ymin) then
      tau = (ymin - y_m)/dy
      if ((tau >= -eps) .and. (tau <= 1.0 + eps) .and. (tau < tau_best)) then
        tau_best = tau
        St = 1.0
        n(1) = 0.0
        n(2) = -1.0
      endif
    endif
    if (y_m1 > ymax) then
      tau = (ymax - y_m)/dy
      if ((tau >= -eps) .and. (tau <= 1.0 + eps) .and. (tau < tau_best)) then
        tau_best = tau
        St = 2.0
        n(1) = 0.0
        n(2) = 1.0
      endif
    endif
  endif

  if (abs(dx) > eps) then
    if (x_m1 < xmin) then
      tau = (xmin - x_m)/dx
      if ((tau >= -eps) .and. (tau <= 1.0 + eps) .and. (tau < tau_best)) then
        tau_best = tau
        St = 3.0
        n(1) = -1.0
        n(2) = 0.0
      endif
    endif
    if (x_m1 > xmax) then
      tau = (xmax - x_m)/dx
      if ((tau >= -eps) .and. (tau <= 1.0 + eps) .and. (tau < tau_best)) then
        tau_best = tau
        St = 4.0
        n(1) = 1.0
        n(2) = 0.0
      endif
    endif
  endif

  if (St < 0.5) then
    if ((y_m < ymin) .or. (y_m1 < ymin)) then
      St = 1.0
      n(1) = 0.0
      n(2) = -1.0
      Xcros = min(max(x_m, xmin), xmax)
      Ycros = ymin
    else if ((y_m > ymax) .or. (y_m1 > ymax)) then
      St = 2.0
      n(1) = 0.0
      n(2) = 1.0
      Xcros = min(max(x_m, xmin), xmax)
      Ycros = ymax
    else if ((x_m < xmin) .or. (x_m1 < xmin)) then
      St = 3.0
      n(1) = -1.0
      n(2) = 0.0
      Xcros = xmin
      Ycros = min(max(y_m, ymin), ymax)
    else if ((x_m > xmax) .or. (x_m1 > xmax)) then
      St = 4.0
      n(1) = 1.0
      n(2) = 0.0
      Xcros = xmax
      Ycros = min(max(y_m, ymin), ymax)
    else
      return
    endif
  else
    Xcros = x_m + tau_best*dx
    Ycros = y_m + tau_best*dy
    Xcros = min(max(Xcros, xmin), xmax)
    Ycros = min(max(Ycros, ymin), ymax)
  endif
  ! Boundary events are written to the particle output file in the main loop.
  call Apply_Boundary(Xcros, Ycros, n, u_m, v_m, u_m1, v_m1, w_m1, x_m1, y_m1, dp, BCMode)

end

Subroutine C_ClampPointToBox(X,Y,NI,NJ, xp, yp, eps)
  Real,Dimension(NI,NJ):: X,Y
  real :: xp, yp, eps
  real :: xmin, xmax, ymin, ymax, dx, dy

  xmin = minval(X)
  xmax = maxval(X)
  ymin = minval(Y)
  ymax = maxval(Y)
  dx = xmax - xmin
  dy = ymax - ymin

  xp = min(max(xp, xmin + eps*dx), xmax - eps*dx)
  yp = min(max(yp, ymin + eps*dy), ymax - eps*dy)
end

Subroutine Apply_Boundary(Xcros, Ycros, n, u_m, v_m, u_m1, v_m1, w_m1, x_m1, y_m1, dp, BCMode)
  real:: k_t, k_n, n(2), t(2)
  real:: V_n, V_t, V_mag, dt, alpha
  integer :: BCMode

  t(1) = -n(2)
  t(2) = n(1)
  V_n = u_m*n(1)+v_m*n(2)
  V_t = u_m*t(1)+v_m*t(2)
  V_mag = SQRT(u_m**2+v_m**2)

  if (V_mag > 1E-10) then 
    alpha = ACOS(MIN(1.0, ABS(V_n)/V_mag))
  else 
    alpha = 0.0
  endif 

  if (BCMode == 1) then
    k_t = 1.0-0.4158*alpha+0.4994*(alpha**2)-0.292*(alpha**3)
    k_n = 1.0-2.12*alpha+3.077*(alpha**2)-1.1*(alpha**3)
  else
    k_t = 0.8
    k_n = 0.8
  endif

  u_m1 = k_t*V_t*t(1)-k_n*V_n*n(1)
  v_m1 = k_t*V_t *t(2)-k_n*V_n*n(2)
  if (V_mag > 1E-10) then
    dt = SQRT((x_m1-Xcros)**2+(y_m1-Ycros)**2)/V_mag
  else
    dt = 0.
  endif
  x_m1 = Xcros+u_m1*dt
  y_m1 = Ycros+v_m1*dt
  w_m1 = (u_m1*t(1)+v_m1*t(2))*2.0/dp

end

Subroutine cross_edges(Ax, Ay, Bx, By, Cx, Cy, Dx, Dy, Xcros, Ycros,Icr)
  real :: Ax, Ay, Bx, By, Cx, Cy, Dx, Dy
  real :: Xcros, Ycros
  real :: Icr
  real :: t, u, prov
  real :: Rx, Ry, Sx, Sy

  Rx = Bx - Ax
  Ry = By - Ay

  Sx = Dx - Cx
  Sy = Dy - Cy

  prov = Rx * Sy - Ry * Sx
  if (abs(prov) <= 1.e-12) then 
    Icr = 0.0
    return
  end if

  t = ((Cx - Ax) * Sy - (Cy - Ay) * Sx) / prov
  u = ((Cx - Ax) * Ry - (Cy - Ay) * Rx) / prov

  if ((t >= 0.0) .and. (t <= 1.0) .and. (u >= 0.0) .and. (u <= 1.0)) then
    Xcros = Ax + t * Rx
    Ycros = Ay + t * Ry
    Icr = 1.0  
  else
    Icr = 0.0  
  end if

end

