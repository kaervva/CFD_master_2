Subroutine c_ForceDetailed(ro1, ro2, mu, dp, u_m, v_m, w_m, Vx_p, Vy_p, Fx, Fy, Mz, rotV_p, &
                           dt, u_m_prev, v_m_prev, gradp_x, gradp_y, gx, gy, PressureScale, &
                           FDragX, FDragY, FMagX, FMagY, FAddX, FAddY, FGravX, FGravY, &
                           FPressX, FPressY, FxAnalytic, FyAnalytic, MzAnalytic, Re_p, Re_w, MassCorr)
real Re_p, Re_w, V_abs, mu, Mz, kRot
real Vrx, Vry, OmegaRel, Cd, Cm, Cl, MassCorr
real FxNoAdded, FyNoAdded
real FDragX, FDragY, FMagX, FMagY, FAddX, FAddY, FGravX, FGravY, FPressX, FPressY
real FxAnalytic, FyAnalytic, MzAnalytic
real gx, gy, PressureScale

  Vrx = Vx_p - u_m
  Vry = Vy_p - v_m
  V_abs = sqrt(Vrx**2.0 + Vry**2.0) 
  Re_p = dp * ro1 * V_abs / mu                         

  if (Re_p < 1.0e-12) then
    Cd = 1.0
  else
    Cd =(1.0 + 0.179*Re_p**0.5 + 0.013*Re_p) 
  endif

  OmegaRel = 0.5*rotV_p - w_m
  Re_w = dp*ro2*abs(OmegaRel)/mu
  if (Re_w < 100.0) then
    Cl = 1.0
  else
    Cl = 0.091*sqrt(Re_w)+0.0017*Re_w
  endif

  Cm = 0.75
  kRot = 60.0*mu/(dp**2.0*ro2)

  FDragX = 18.0*Cd*mu/(dp**2.0*ro2)*Vrx
  FDragY = 18.0*Cd*mu/(dp**2.0*ro2)*Vry

  FMagX = -(ro1/ro2)*Cm*Vry*OmegaRel
  FMagY = (ro1/ro2)*Cm*Vrx*OmegaRel

  FGravX = gx
  FGravY = gy
  FPressX = -(ro1/ro2)*PressureScale*gradp_x
  FPressY = -(ro1/ro2)*PressureScale*gradp_y
  MassCorr = 1.0 + 0.5*ro1/ro2
  FxNoAdded = FDragX + FMagX + FGravX + FPressX
  FyNoAdded = FDragY + FMagY + FGravY + FPressY
  FxAnalytic = FxNoAdded/MassCorr
  FyAnalytic = FyNoAdded/MassCorr
  FAddX = -0.5*ro1/ro2*FxAnalytic
  FAddY = -0.5*ro1/ro2*FyAnalytic

  MzAnalytic = kRot*OmegaRel

  Fx = FxAnalytic
  Fy = FyAnalytic
  Mz = MzAnalytic
end

Subroutine Search_p(x_m, y_m, NI, Nj, X, Y, CellVolume, IP, JP)
real s_1, s_2, s_3, s_4, s, eps
REAL CellVolume(NI-1,NJ-1), X(NI, NJ), Y(NI, NJ)
integer IP, JP

eps = 1.e-5

do i = 1, NI-1
  do j = 1, NJ-1
    s_1 = square(x_m, x(i,j), x(i+1,j), y_m, y(i,j), y(i+1,j))
    s_2 = square(x_m, x(i+1,j+1), x(i, j+1), y_m, y(i+1,j+1), y(i,j+1))
    s_3 = square(x_m, x(i,j+1), x(i, j), y_m, y(i,j+1), y(i,j))
    s_4 = square(x_m, x(i+1,j), x(i+1,j+1), y_m, y(i+1,j), y(i+1,j+1))
    s = s_1+s_2+s_3+s_4

    if (abs(s-CellVolume(i, j)) <= eps) then 
      IP = i 
      JP = j 
      RETURN
    else
      IP = -1
      JP = -1 
    end if
  end do
end do

end Subroutine

Function Square(X_1,X_2,X_3, Y_1, Y_2, Y_3)
real p, l_1, l_2, l_3
  
  l_1 = sqrt((x_1-x_2)**2+(y_1-y_2)**2)
  l_2 = sqrt((X_3-x_2)**2+(y_3-y_2)**2)
  l_3 = sqrt((x_1-x_3)**2+(y_1-y_3)**2)
  p = (l_1+l_2+l_3)/2.
  !print*, p
  Square = sqrt(p*(p-l_1)*(p-l_2)*(p-l_3))
End Function


Subroutine B_CalcGradient(ni,nj,CellCenter,CellVolume,IFaceCenter,IFaceVector,JFaceCenter,JFaceVector,T, gradT)
REAL CellCenter(0:NI,0:NJ,2),CellVolume(NI-1,NJ-1),&              !cell centers and volumes
      IFaceCenter( NI,NJ-1,2),IFaceVector( NI,NJ-1,2),&           !face centers and vectors for I-faces
      JFaceCenter( NI-1,NJ,2),JFaceVector( NI-1,NJ,2)            !face centers and vectors for J-faces
Real,Dimension(0:NI,0:NJ)::T
Real,Dimension(1:NI-1,1:NJ-1,2)::gradT, gradT_new
integer iNeighCell(4), jNeighCell(4)
real rc(2), rn(2), sf(4,2), rf(4,2), RE(2), GTE(2)

gradT_new = 0

do i=1,ni-1
    do j = 1,nj-1

      Sf(1,:) = -IFaceVector(i,j,:)
      Sf(2,:) = -JFaceVector(i,j,:)
      Sf(3,:) = JFaceVector(i,j+1,:)
      Sf(4,:) = IFaceVector(i+1,j,:)

      rf(1,:) = IFaceCenter(i,j,:)
      rf(2,:) = JFaceCenter(i,j,:)
      rf(3,:) = JFaceCenter(i,j+1,:)
      rf(4,:) = IFaceCenter(i+1,j,:)

      !prepare i and j for each of 4 neighbouring cells
      iNeighCell(1) = i-1
      jNeighCell(1) = J

      iNeighCell(2) = I
      jNeighCell(2) = j-1

      iNeighCell(3) = i 
      jNeighCell(3) = j+1

      iNeighCell(4) =  i+1
      jNeighCell(4) = j

      do iface = 1, 4
        in = iNeighCell(iface)
        jn = jNeighCell(iface)

        RC = CellCenter(i,j,:)
        RN = CellCenter(in,jn,:)
        
        d = norm2(rf(iface,:)-rc)
        dn = norm2(rf(iface,:)-rn)

        RE(1) = RLinearInterp(d, dn, RC(1), RN(1))
        RE(2) = RLinearInterp(d, dn, RC(2), RN(2))

        if (dn > 1.e-7) then
          GTE(1) = RLinearInterp(d, dn, gradT(i,j,1), gradT(in,jn,1))
          GTE(2) = RLinearInterp(d, dn, gradT(i,j,2), gradT(in,jn,2))
        else
          GTE(:) = GradT(i,j,:)
        endif

        Tf = RLinearInterp(d,dn,T(i,j),T(in,jn))
        Tf = Tf + DOT_PRODUCT(RF(iface,:)-RE,GTE)

        gradT_new(i,j,:) = gradT_new(i,j,:)+Sf(iface,:)*Tf
      end do


      gradT_new(i,j,:) = gradT_new(i,j,:)/CellVolume(i,j)

    end do 
end do    

GradT = GradT_new

End Subroutine 

Subroutine B_CalcDivergence(ni,nj,CellCenter,CellVolume,IFaceCenter,IFaceVector,JFaceCenter,JFaceVector,T,V, divVT, gradT, &
            P, gradP,dt,mode,mbc,mrc)
REAL CellCenter(0:NI,0:NJ,2),CellVolume(NI-1,NJ-1),&              !cell centers and volumes
      IFaceCenter( NI,NJ-1,2),IFaceVector( NI,NJ-1,2),&           !face centers and vectors for I-faces
      JFaceCenter( NI-1,NJ,2),JFaceVector( NI-1,NJ,2)            !face centers and vectors for J-faces

Real,Dimension(0:NI,0:NJ)::T, P
Real,Dimension(0:NI,0:NJ,2)::V
Real,Dimension(NI-1,NJ-1)::divVt
Real,Dimension(1:NI-1,1:NJ-1,2)::gradP, gradT

integer iNeighCell(4), jNeighCell(4)
real rc(2), rn(2), sf(4,2), rf(4,2), Vf(2), ePN(2), gradPf(2)

divVT=0

do i=1,ni-1
    do j = 1,nj-1

      Sf(1,:) = -IFaceVector(i,j,:)
      Sf(2,:) = -JFaceVector(i,j,:)
      Sf(3,:) = JFaceVector(i,j+1,:)
      Sf(4,:) = IFaceVector(i+1,j,:)

      rf(1,:) = IFaceCenter(i,j,:)
      rf(2,:) = JFaceCenter(i,j,:)
      rf(3,:) = JFaceCenter(i,j+1,:)
      rf(4,:) = IFaceCenter(i+1,j,:)

      !prepare i and j for each of 4 neighbouring cells
      iNeighCell(1) = i-1
      jNeighCell(1) = J

      iNeighCell(2) = I
      jNeighCell(2) = j-1

      iNeighCell(3) = i 
      jNeighCell(3) = j+1

      iNeighCell(4) =  i+1
      jNeighCell(4) = j

      do iface = 1, 4
        in = iNeighCell(iface)
        jn = jNeighCell(iface)

        RC = CellCenter(i,j,:)
        RN = CellCenter(in,jn,:)
        
        d = norm2(rf(iface,:)-rc)
        dn = norm2(rf(iface,:)-rn)

        Vf(1) =  RLinearInterp(d, dn, V(i,j,1), V(in,jn,1))
        Vf(2) =  RLinearInterp(d, dn, V(i,j,2), V(in,jn,2))
        
        ! === RHIE-CHOW CORRECTION ===
        if ((mrc == 1) .and. (dn>=1e-7)) then 
          ePN(:) = (RN(:)-RC(:))/(d+dn)
          gradPf(1) = RLinearInterp(d, dn, gradP(i,j,1), gradP(in,jn,1))
          gradPf(2) = RLinearInterp(d, dn, gradP(i,j,2), gradP(in,jn,2))
          RCcorr = (P(in,jn)-P(i,j))/(d+dn) - DOT_PRODUCT(gradPf(:),ePN(:))
          Vf(:) = Vf(:) - dt*RCcorr*ePN(:)
        endif

        select case(mode)
        case(0) !div(V)
          Tf = 1
        case(1) !upwind
          Gn = DOT_PRODUCT(Vf,Sf(iface,:))
          if (Gn >= 0.0) then
            Tf = T(i, j)
          else 
            Tf = T(in, jn)
            if (dn < 1.e-7) then 
              Tf = T(in, jn) + (T(in, jn) - T(i, j))
            endif
          endif

        case(2) !central
          Tf = RLinearInterp(d,dn,T(i,j),T(in,jn))
        case(3) !SOU
          Gn = DOT_PRODUCT(Vf,Sf(iface,:))
          if (Gn >= 0.0) then
            select case(iface)
              case(1)    
                i_up2 = i+1
                j_up2 = j
              case(2)    
                i_up2 = i
                j_up2 = j+1
              case(3)    
                i_up2 = i
                j_up2 = j-1
              case(4)  
                i_up2 = i-1
                j_up2 = j
            end select
            if ((i_up2 >= 1) .and. (i_up2 <= NI-1) .and. (j_up2 >= 1) .and. (j_up2 <= NJ-1)) then
              Tf = T(i,j) + (T(i,j)-T(i_up2,j_up2)) * (d / norm2(CellCenter(i_up2,j_up2,:)-rc))
            else 
              Tf = T(i,j) + dot_product(GradT(i,j,:),rf(iface,:) - CellCenter(i,j,:))
            endif
          else 
            select case(iface)
              case(1)    
                i_up2 = in-1
                j_up2 = jn
              case(2)    
                i_up2 = in
                j_up2 = jn-1
              case(3)    
                i_up2 = in
                j_up2 = jn+1
              case(4)  
                i_up2 = in+1
                j_up2 = jn
            end select
            if ((i_up2 >= 1) .and. (i_up2 <= NI-1) .and. (j_up2 >= 1) .and. (j_up2 <= NJ-1)) then
              Tf = T(in,jn) + (T(in,jn)-T(i_up2,j_up2))*(dn / norm2(CellCenter(i_up2,j_up2,:)-rn))
            else 
              if (dn <= 1.e-7) then 
                Tf = 2*T(in,jn) - T(i,j) - 4*T(in,jn) + 4*T(i,j)&
                           + 3*dot_product(GradT(i,j,:),rf(iface,:)-CellCenter(i,j,:))
              else
                Tf = T(in,jn) + dot_product(GradT(in,jn,:),rf(iface,:) - CellCenter(in,jn,:))
              endif
            endif
          endif

        case(4) !upwind gradient based
          Gn = DOT_PRODUCT(Vf,Sf(iface,:))
          if (Gn >= 0.0) then
            Tf = T(i,j) + dot_product(GradT(i,j,:),rf(iface,:) - CellCenter(i,j,:))
          else 
            if (dn < 1e-7) then
              Tf = 2*T(in,jn) - T(i,j) - 4*T(in,jn) + 4*T(i,j) +&
                          3*dot_product(GradT(i,j,:),rf(iface,:)-CellCenter(i,j,:))
            else
              Tf = T(in,jn) + dot_product(GradT(in,jn,:),rf(iface,:) - CellCenter(in,jn,:))
            end if
          endif
        end select

        if ((dn <= 1.e-7) .and. (mbc == 1)) Vf = 0

        divVT(i,j) = divVT(i,j)+Tf*DOT_PRODUCT(Vf(:),Sf(iface,:))
      end do

      divVT(i,j) = divVT(i,j)/CellVolume(i,j)

    end do 
end do    

End Subroutine 

Subroutine B_CalcLaplacian(ni,nj,CellCenter,CellVolume,IFaceCenter,IFaceVector,JFaceCenter,JFaceVector,T, gradT, LapT, mbc)
REAL CellCenter(0:NI,0:NJ,2),CellVolume(NI-1,NJ-1),&              !cell centers and volumes
      IFaceCenter( NI,NJ-1,2),IFaceVector( NI,NJ-1,2),&           !face centers and vectors for I-faces
      JFaceCenter( NI-1,NJ,2),JFaceVector( NI-1,NJ,2)            !face centers and vectors for J-faces
Real,Dimension(0:NI,0:NJ)::T
Real,Dimension(1:NI-1,1:NJ-1)::LapT
Real,Dimension(1:NI-1,1:NJ-1,2)::gradT
integer iNeighCell(4), jNeighCell(4)
real rc(2), rn(2), sf(4,2), rf(4,2), NF(2), RNC(2), GTF(2)

LapT=0
do i=1,ni-1
    do j = 1,nj-1

      Sf(1,:) = -IFaceVector(i,j,:)
      Sf(2,:) = -JFaceVector(i,j,:)
      Sf(3,:) = JFaceVector(i,j+1,:)
      Sf(4,:) = IFaceVector(i+1,j,:)

      rf(1,:) = IFaceCenter(i,j,:)
      rf(2,:) = JFaceCenter(i,j,:)
      rf(3,:) = JFaceCenter(i,j+1,:)
      rf(4,:) = IFaceCenter(i+1,j,:)

      !prepare i and j for each of 4 neighbouring cells
      iNeighCell(1) = i-1
      jNeighCell(1) = j

      iNeighCell(2) = i
      jNeighCell(2) = j-1

      iNeighCell(3) = i 
      jNeighCell(3) = j+1

      iNeighCell(4) = i+1
      jNeighCell(4) = j

      do iface = 1, 4
        in = iNeighCell(iface)
        jn = jNeighCell(iface)

        RC = CellCenter(i,j,:)
        RN = CellCenter(in,jn,:)
        
        d = norm2(rf(iface,:)-rc)
        dn = norm2(rf(iface,:)-rn)

        DNC = norm2(rn-rc) 
        RNC = (RN - RC)/DNC !i_ksi
        dTdn=(T(in,jn)-T(i,j))/DNC

        if (dn > 1.e-7) then
          GTF(1) = RLinearInterp(d, dn, GradT(i,j,1), GradT(in,jn,1))
          GTF(2) = RLinearInterp(d, dn, GradT(i,j,2), GradT(in,jn,2))
        else
          GTF(:) = GradT(i,j,:)
        endif

        NF(:) = Sf(iface,:)/norm2(Sf(iface,:))

        if (dn<=1e-7) then
          dTdn_c = DOT_PRODUCT(gradT(i,j,:),NF(:))
          !dTdn = dTdn+(dTdn-dTdn_c) !first order on boundary
          dTdn = 5./3.*dTdn - 2./3.*dTdn_c !2-order for uniform mesh
          GTF(:) = GradT(i,j,:)
        endif

        dTdn = dTdn + DOT_PRODUCT(NF-RNC, GTF)

        if ((mbc == 1) .and. ((jn == NJ) .or. (jn == 0))) dTdn = 0. 

        LapT(i,j) = LapT(i,j)+dTdn*norm2(Sf(iface,:))
      end do

      LapT(i,j) = LapT(i,j)/CellVolume(i,j)

    end do 
end do    

End Subroutine 

