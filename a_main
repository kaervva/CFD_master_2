Subroutine C_RunParticleOutputCase(NI, NJ, X, Y, CellCenter, CellVolume, IFaceVector, JFaceVector, V, gradP, rotV, &
                                   ro1, ro2, mu, dp, x0, y0, u0, v0, w0, dt, Nt, Scheme, ParamScheme, BCMode, &
                                   gx, gy, PressureScale, CaseTag)
  integer, parameter :: IOP = 27
  integer :: NI, NJ, Nt, Scheme, ParamScheme, BCMode
  integer :: m, IP, JP, IP1, JP1
  real :: ro1, ro2, mu, dp, x0, y0, u0, v0, w0, dt, gx, gy, PressureScale
  real :: x_m, y_m, u_m, v_m, w_m, x_m1, y_m1, u_m1, v_m1, w_m1
  real :: u_m_prev, v_m_prev
  real :: rhs_x, rhs_y, rhs_u, rhs_v, rhs_w
  real :: rhs_x_old, rhs_y_old, rhs_u_old, rhs_v_old, rhs_w_old
  real :: Vx_p, Vy_p, rotV_p, gradPx_p, gradPy_p
  real :: Vx_center, Vy_center, rotV_center, gradPx_center, gradPy_center
  real :: Vx_idw, Vy_idw, rotV_idw, gradPx_idw, gradPy_idw
  real :: Fx, Fy, Mz, FDragX, FDragY, FMagX, FMagY, FAddX, FAddY, FGravX, FGravY
  real :: FPressX, FPressY, FxAnalytic, FyAnalytic, MzAnalytic, RePart, ReRot, MassCorr
  real :: Xcros, Ycros, St
  Real,Dimension(NI,NJ):: X,Y
  Real,Dimension(0:NI,0:NJ,2):: CellCenter, V
  Real,Dimension(NI-1,NJ-1):: CellVolume, rotV
  Real,Dimension(NI,NJ-1,2):: IFaceVector
  Real,Dimension(NI-1,NJ,2):: JFaceVector
  Real,Dimension(1:NI-1,1:NJ-1,2):: gradP
  character*(*) CaseTag
  character PartFile*160

  PartFile = 'output_particle_param_'//trim(CaseTag)//'.dat'

  x_m = x0
  y_m = y0
  u_m = u0
  v_m = v0
  w_m = w0
  u_m_prev = u_m
  v_m_prev = v_m
  rhs_x_old = u_m
  rhs_y_old = v_m
  rhs_u_old = 0.0
  rhs_v_old = 0.0
  rhs_w_old = 0.0

  OPEN(IOP,FILE=PartFile)
  write(IOP,*) 'm, time, x_m, y_m, u_m, v_m, w_m, Fx, Fy, Mz'

  do m = 1, Nt
    IP = -1
    JP = -1
    call Search_p(x_m, y_m, NI, NJ, X, Y, CellVolume, IP, JP)
    if ((IP < 1) .or. (JP < 1)) exit

    call C_InterpolateGas(x_m, y_m, NI, NJ, CellCenter, V, gradP, rotV, IP, JP, 1, &
                          Vx_center, Vy_center, rotV_center, gradPx_center, gradPy_center)
    call C_InterpolateGas(x_m, y_m, NI, NJ, CellCenter, V, gradP, rotV, IP, JP, 2, &
                          Vx_idw, Vy_idw, rotV_idw, gradPx_idw, gradPy_idw)

    if (ParamScheme == 2) then
      Vx_p = Vx_idw
      Vy_p = Vy_idw
      rotV_p = rotV_idw
      gradPx_p = gradPx_idw
      gradPy_p = gradPy_idw
    else
      Vx_p = Vx_center
      Vy_p = Vy_center
      rotV_p = rotV_center
      gradPx_p = gradPx_center
      gradPy_p = gradPy_center
    endif

    call c_ForceDetailed(ro1, ro2, mu, dp, u_m, v_m, w_m, Vx_p, Vy_p, Fx, Fy, Mz, rotV_p, &
                         dt, u_m_prev, v_m_prev, gradPx_p, gradPy_p, gx, gy, PressureScale, &
                         FDragX, FDragY, FMagX, FMagY, FAddX, FAddY, FGravX, FGravY, &
                         FPressX, FPressY, FxAnalytic, FyAnalytic, MzAnalytic, RePart, ReRot, MassCorr)

    write(IOP,*) m, m*dt, x_m, y_m, u_m, v_m, w_m, Fx, Fy, Mz

    rhs_x = u_m
    rhs_y = v_m
    rhs_u = Fx
    rhs_v = Fy
    rhs_w = Mz

    if ((Scheme == 2) .and. (m > 1)) then
      x_m1 = x_m + dt*(1.5*rhs_x - 0.5*rhs_x_old)
      y_m1 = y_m + dt*(1.5*rhs_y - 0.5*rhs_y_old)
      u_m1 = u_m + dt*(1.5*rhs_u - 0.5*rhs_u_old)
      v_m1 = v_m + dt*(1.5*rhs_v - 0.5*rhs_v_old)
      w_m1 = w_m + dt*(1.5*rhs_w - 0.5*rhs_w_old)
    else
      x_m1 = x_m + dt*rhs_x
      y_m1 = y_m + dt*rhs_y
      u_m1 = u_m + dt*rhs_u
      v_m1 = v_m + dt*rhs_v
      w_m1 = w_m + dt*rhs_w
    endif

    call Search_p(x_m1, y_m1, NI, NJ, X, Y, CellVolume, IP1, JP1)
    IP = IP1
    JP = JP1
    if ((x_m1 < minval(X)) .or. (x_m1 > maxval(X)) .or. &
        (y_m1 < minval(Y)) .or. (y_m1 > maxval(Y))) then
      IP = -1
      JP = -1
    endif

    if ((IP < 0) .and. (JP < 0)) then
      Xcros = 0.0
      Ycros = 0.0
      St = 0.0
      call C_Boundary(X,Y,IFaceVector, JFaceVector, NI, NJ, x_m, y_m, u_m, v_m, w_m, x_m1, &
                      y_m1, u_m1, v_m1, w_m1, Xcros, Ycros, St, dp, BCMode)
      if (St < 0.5) then
        call C_BoundaryFallbackBox(X,Y,NI,NJ, x_m, y_m, u_m, v_m, w_m, x_m1, &
                                  y_m1, u_m1, v_m1, w_m1, Xcros, Ycros, St, dp, BCMode)
      endif
      if (St < 0.5) exit
      call C_ClampPointToBox(X,Y,NI,NJ, Xcros, Ycros, 0.0)
      call C_ClampPointToBox(X,Y,NI,NJ, x_m1, y_m1, 1.0e-6)
      write(IOP,*) m, m*dt, Xcros, Ycros, u_m, v_m, w_m, Fx, Fy, Mz
    endif

    u_m_prev = u_m
    v_m_prev = v_m
    rhs_x_old = rhs_x
    rhs_y_old = rhs_y
    rhs_u_old = rhs_u
    rhs_v_old = rhs_v
    rhs_w_old = rhs_w
    x_m = x_m1
    y_m = y_m1
    u_m = u_m1
    v_m = v_m1
    w_m = w_m1
  enddo

  CLOSE(IOP)
end

Subroutine C_RestingLiquidForceMomentCompare(ro1, ro2, mu, dp, u0, v0, w0, dt, Nt, Scheme, RunTag)
  integer, parameter :: IOR = 15
  integer :: Nt, Scheme, m
  real :: ro1, ro2, mu, dp, u0, v0, w0, dt
  real :: t, kDrag, kRot
  real :: u_num, v_num, w_num, u_next, v_next, w_next
